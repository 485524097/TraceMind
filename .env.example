# Application
APP_NAME=TraceMind API
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
HEALTHCHECK_TIMEOUT_SECONDS=2

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=tracemind
POSTGRES_PASSWORD=tracemind-local-only
POSTGRES_DB=tracemind
DATABASE_URL=
POSTGRES_HOST_PORT=5432

# Redis
REDIS_PASSWORD=tracemind-local-only
REDIS_URL=redis://:tracemind-local-only@127.0.0.1:6379/0
REDIS_HOST_PORT=6379

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

# Celery
CELERY_BROKER_URL=redis://:tracemind-local-only@127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://:tracemind-local-only@127.0.0.1:6379/2

# Application ports
BACKEND_HOST_PORT=8000
