# Application
APP_NAME=TraceMind API
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
HEALTHCHECK_TIMEOUT_SECONDS=2

# Document ingestion (local host paths)
DOCUMENT_STORAGE_ROOT=../data/uploads
DOCUMENT_STORAGE_HOST_PATH=./data/uploads
DOCUMENT_MAX_FILE_SIZE_BYTES=52428800
DOCUMENT_UPLOAD_CHUNK_SIZE_BYTES=1048576
DOCUMENT_ALLOWED_EXTENSIONS=.md,.txt,.pdf,.docx,.java,.jsp,.js,.ts,.vue,.sql,.xml,.json,.yaml,.yml,.properties,.py
DOCUMENT_PARSE_MAX_EXTRACTED_CHARS=5000000
DOCUMENT_PARSE_MAX_PDF_PAGES=1000
DOCUMENT_PARSE_STALE_AFTER_SECONDS=1800
DOCUMENT_CHUNK_MAX_CHARS=1800
DOCUMENT_CHUNK_OVERLAP_CHARS=200

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=tracemind
POSTGRES_PASSWORD=tracemind-local-only
POSTGRES_DB=tracemind
DATABASE_URL=
POSTGRES_HOST_PORT=5432

# Redis
REDIS_PASSWORD=tracemind-local-only
REDIS_URL=redis://:tracemind-local-only@127.0.0.1:6379/0
REDIS_HOST_PORT=6379

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_NAME=tracemind_chunks
QDRANT_DENSE_VECTOR_NAME=dense_v1
QDRANT_OPERATION_TIMEOUT_SECONDS=60
QDRANT_UPSERT_BATCH_SIZE=64
SEMANTIC_SEARCH_SCORE_THRESHOLD=0.50
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

# Dense embedding and indexing
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DEVICE=auto
DOCUMENT_INDEX_STALE_AFTER_SECONDS=1800

# Celery
CELERY_BROKER_URL=redis://:tracemind-local-only@127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://:tracemind-local-only@127.0.0.1:6379/2

# Application ports
BACKEND_HOST_PORT=8000
